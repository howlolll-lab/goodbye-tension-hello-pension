
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Goodbye tension, hello pension</title>

<style>
body{
font-family:Arial, sans-serif;
background:#f5f6f7;
margin:0;
padding:20px;
}

.container{
max-width:900px;
margin:auto;
}

.card{
background:white;
padding:20px;
border-radius:10px;
margin-bottom:15px;
border:1px solid #e5e7eb;
}

h1{
font-weight:300;
}

button{
padding:8px 14px;
border-radius:8px;
border:1px solid #ccc;
cursor:pointer;
}

.primary{
background:#0f766e;
color:white;
border:none;
}

input{
padding:8px;
border-radius:8px;
border:1px solid #ccc;
width:100%;
margin-top:6px;
}

.item{
display:flex;
justify-content:space-between;
padding:8px;
border-bottom:1px solid #eee;
}

.done{
text-decoration:line-through;
color:gray;
}

.topbar{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:15px;
}

.overlay{
position:fixed;
top:0;
left:0;
right:0;
bottom:0;
background:rgba(0,0,0,0.4);
display:flex;
justify-content:center;
align-items:center;
}

.login{
background:white;
padding:25px;
border-radius:10px;
width:300px;
}
</style>

</head>
<body>

<div class="overlay" id="loginOverlay">
<div class="login">

<h3>Login</h3>

<input type="password" id="loginPass" placeholder="password">

<br><br>

<button class="primary" onclick="login()">Sign in</button>

</div>
</div>


<div class="container">

<div class="topbar">
<h1>Goodbye tension, hello pension</h1>
<button onclick="logout()">Logout</button>
</div>


<div class="card">

<h3>Logout Countdown</h3>

<input type="date" id="logoutDate">

<h2 id="daysLeft">-</h2>

</div>


<div class="card">

<h3>Checklist</h3>

<input id="taskInput" placeholder="New task">

<br><br>

<button class="primary" onclick="addTask()">Add</button>

<div id="taskList"></div>

</div>


<div class="card">

<h3>Settings</h3>

<label>Current Password</label>
<input id="currentPass" type="password">

<label>New Password</label>
<input id="newPass" type="password">

<button onclick="changePassword()">Change Password</button>

</div>


</div>

<script>

const PASS_KEY="app_password"
const TASK_KEY="app_tasks"

if(!localStorage.getItem(PASS_KEY)){
localStorage.setItem(PASS_KEY,"123456")
}

function login(){

let p=document.getElementById("loginPass").value

if(p===localStorage.getItem(PASS_KEY)){
document.getElementById("loginOverlay").style.display="none"
}else{
alert("Wrong password")
}

}

function logout(){

document.getElementById("loginOverlay").style.display="flex"

}

function changePassword(){

let current=document.getElementById("currentPass").value
let next=document.getElementById("newPass").value

if(current!==localStorage.getItem(PASS_KEY)){
alert("Wrong current password")
return
}

if(next.length<6){
alert("Password must be 6 characters")
return
}

localStorage.setItem(PASS_KEY,next)

alert("Password changed")

}

function addTask(){

let text=document.getElementById("taskInput").value

if(!text)return

let tasks=JSON.parse(localStorage.getItem(TASK_KEY)||"[]")

tasks.push({text,done:false})

localStorage.setItem(TASK_KEY,JSON.stringify(tasks))

document.getElementById("taskInput").value=""

renderTasks()

}

function toggleTask(i){

let tasks=JSON.parse(localStorage.getItem(TASK_KEY)||"[]")

tasks[i].done=!tasks[i].done

localStorage.setItem(TASK_KEY,JSON.stringify(tasks))

renderTasks()

}

function renderTasks(){

let tasks=JSON.parse(localStorage.getItem(TASK_KEY)||"[]")

let html=""

tasks.forEach((t,i)=>{

html+=`<div class="item ${t.done?"done":""}">
<span onclick="toggleTask(${i})">${t.text}</span>
</div>`

})

document.getElementById("taskList").innerHTML=html

}

renderTasks()

document.getElementById("logoutDate").addEventListener("change",function(){

let target=new Date(this.value)
let today=new Date()

let diff=target-today

let days=Math.ceil(diff/(1000*60*60*24))

document.getElementById("daysLeft").innerText=days+" days"

})

</script>

</body>
</html>
